{"name":"H2. Calculator - II","group":"Codeforces - Introduction to C++","url":"https://codeforces.com/group/4vcXCPx8NY/contest/664504/problem/H2","interactive":false,"memoryLimit":256,"timeLimit":1000,"tests":[{"id":1769428599673,"input":"1000000000\n1000000000\n","output":"1000000000 + 1000000000 = 2000000000\n\n1000000000 - 1000000000 = 0\n\n1000000000 * 1000000000 = 1000000000000000000\n\n1000000000 / 1000000000 = 1\n\n1000000000 % 1000000000 = 0\n"}],"testType":"single","input":{"type":"stdin"},"output":{"type":"stdout"},"languages":{"java":{"mainClass":"Main","taskClass":"H2CalculatorII"}},"batch":{"id":"bec5c3b6-59d8-4eda-8028-2b1464554bd8","size":1},"srcPath":"/home/jjf2009/Desktop/Projects/100xdevs/DSA/H_2_Calculator_II.cpp"}